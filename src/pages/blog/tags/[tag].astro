---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedPosts, getPostsByTag, readingTimeMinutes } from '@/lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Set<string>();
  posts.forEach((p) => p.data.tags.forEach((t) => tags.add(t)));
  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = await getPostsByTag(tag!);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout
  title={`#${tag} — TokenJam Blog`}
  description={`Posts tagged #${tag} on the TokenJam blog.`}
>
  <header class="blog-hero">
    <h1>#{tag}</h1>
    <p>{posts.length} post{posts.length === 1 ? '' : 's'}</p>
  </header>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-meta">
            <time>{fmt(post.data.publishDate)}</time>
            <span>·</span>
            <span>{readingTimeMinutes(post.body)} min read</span>
          </div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
