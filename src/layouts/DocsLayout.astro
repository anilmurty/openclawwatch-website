---
import BaseLayout from './BaseLayout.astro';
import CopyForAI from '@/components/CopyForAI.astro';
import Schema from '@/components/Schema.astro';
import { breadcrumbSchema } from '@/lib/schema';
import type { CollectionEntry } from 'astro:content';

interface Props {
  doc: CollectionEntry<'docs'>;
}
const { doc } = Astro.props;
const SITE = 'https://tokenjam.dev';

const crumbs = [
  { name: 'Home', url: SITE },
  { name: 'Docs', url: `${SITE}/docs` },
  { name: doc.data.title, url: `${SITE}/docs/${doc.id}` },
];
---
<BaseLayout
  title={`${doc.data.title} — TokenJam Docs`}
  description={doc.data.description}
>
  <article>
    <header class="article-header">
      <h1>{doc.data.title}</h1>
      <div class="article-byline">
        {doc.data.lastUpdated && (
          <span>Updated {doc.data.lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        )}
      </div>
    </header>
    <CopyForAI />
    <div class="prose">
      <slot />
    </div>
  </article>
  <Schema data={breadcrumbSchema(crumbs)} />
</BaseLayout>
